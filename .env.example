# Xray executable path
XRAY_PATH="/opt/homebrew/bin/xray"

# Output configuration file name
CONFIG_FILE_NAME="xray.json"

# Full path to the output configuration file (optional, overrides CONFIG_FILE_NAME)
# CONFIG_PATH="/path/to/xray.json"

# Starting port for SOCKS5 proxies
SOCKS_START_PORT=50000

# Server port to listen on
SERVER_PORT=3123

# Default user level for Xray config
DEFAULT_USER_LEVEL=8

# Default fingerprint for TLS/Reality
DEFAULT_FINGERPRINT="safari"

# Loopback address to bind to
LOOPBACK_ADDRESS="127.0.0.1"

# User Agent to use when fetching subscriptions
SUBSCRIPTION_USER_AGENT="v2rayNG/1.8.5"

# Comma-separated keywords to filter out proxies by name
FILTER_KEYWORDS=""
